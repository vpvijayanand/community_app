//Using passthrough proxy endpoint
{
  "apiKeyHelper": "python3 ~/portal-ai-scripts/get-portal-token.py",
  "env": {
    "CLAUDE_CODE_API_KEY_HELPER_TTL_MS": "21600000",
    "ANTHROPIC_VERTEX_BASE_URL": "https://portal.ai.pubc.worldline-solutions.com/vertex_ai/v1",
    "ANTHROPIC_VERTEX_PROJECT_ID": "glb-grs-gcp-sbx-dev",
    "CLOUD_ML_REGION": "europe-west1",
    "VERTEX_REGION_CLAUDE_4_7_OPUS": "eu",
    "CLAUDE_CODE_USE_VERTEX": "1",
    "CLAUDE_CODE_SKIP_VERTEX_AUTH": "1",
    "ANTHROPIC_DEFAULT_OPUS_MODEL": "claude-opus-4-7",
    "ANTHROPIC_DEFAULT_SONNET_MODEL": "claude-sonnet-4-6",
    "ANTHROPIC_DEFAULT_HAIKU_MODEL": "claude-haiku-4-5"
  },
  "model": "sonnet"
}

