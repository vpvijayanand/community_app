# --- Server ---
NODE_ENV=development
PORT=4000
CORS_ORIGIN=http://localhost:3000

# --- Postgres ---
# Either set DATABASE_URL or the individual PG* variables.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/mathat_news
# PGHOST=localhost
# PGPORT=5432
# PGUSER=postgres
# PGPASSWORD=postgres
# PGDATABASE=mathat_news
# PGSSL=false

# --- Auth ---
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false

# --- Seeding ---
SEED_ADMIN_EMAIL=admin@mathat.local
SEED_ADMIN_PASSWORD=change-me-admin-password
