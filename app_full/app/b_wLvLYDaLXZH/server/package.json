{
  "name": "mathat-news-server",
  "version": "1.0.0",
  "description": "Express + PostgreSQL backend for the Mathat Kula community news platform.",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "node --watch --env-file=.env src/index.js",
    "start": "node --env-file=.env src/index.js",
    "migrate": "node --env-file=.env src/database/migrate.js",
    "seed": "node --env-file=.env src/database/seed.js",
    "reset": "node --env-file=.env src/database/migrate.js --drop && npm run migrate && npm run seed"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "pg": "^8.12.0",
    "zod": "^3.23.8"
  }
}
